  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
}

// 头像上传区域样式
.avatar-upload {
  position: relative;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  overflow: hidden;
  cursor: pointer;
  flex-shrink: 0;

  &:hover {
    .avatar-overlay {
      opacity: 1;
    }
  }
}

.user-avatar {
  width: 100%;
