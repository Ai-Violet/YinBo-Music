  transition: transform 0.2s;
}

/* 箭头旋转样式 - 仅在下拉菜单显示时生效 */
.user-info .dropdown-arrow.arrow-rotated {
  transform: rotate(180deg);
}

.action-buttons {
  display: flex;
  gap: 4px;

  :deep(.el-button) {
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: #666;
    transition: all 0.2s;

    &:hover {
      background: #f5f5f5;
      color: #C20C0C;
    }
  }
}

// 下拉菜单中的用户数据样式
.user-stats-dropdown {
  display: flex;
  justify-content: space-around;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;

  .stat-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;

    .stat-value {
      font-size: 20px;
      font-weight: 600;
      color: #333;
    }

    .stat-label {
      font-size: 12px;
      color: #999;
    }
  }

  .stat-divider {
    width: 1px;
    background-color: #f0f0f0;
  }
}

// 下拉菜单样式优化
:deep(.el-dropdown-menu) {
  .el-dropdown-menu__item {
    display: flex;
    align-items: center;
    gap: 8px;

    .el-icon {
      font-size: 16px;
    }
  }
}
