    box-shadow: none;
    padding: 8px 15px;

    &:hover {
      background: #f0f0f0;
    }

    &.is-focus {
      background: #fff;
      box-shadow: 0 0 0 1px #C20C0C;
    }
  }

  :deep(.el-input__inner) {
    color: #333;
    &::placeholder {
      color: #999;
    }
  }
}

